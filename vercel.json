{
  "redirects": [
    {
      "source": "/",
      "destination": "/raw/bypass.user.js",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/raw/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}